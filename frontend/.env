# Vite frontend — local development
# Default dev server: http://localhost:3001 (run: npm run dev)
# Proxies /api → NestJS backend (Admin Console, auth, dashboard, etc.)

BACKEND_HOST=localhost
BACKEND_PORT=5000

VITE_PROXY_WORKER_TARGET=http://127.0.0.1:4000
VITE_PROXY_COLLECTOR_TARGET=http://127.0.0.1:8080

# Optional UI labels (only if your code reads them)
# VITE_API_URL=http://localhost:8080
# VITE_APP_TITLE=SmartSIEM
# VITE_APP_VERSION=1.0.0
